// Lab Test Requirement - Users submit requirements, labs respond
model LabTestRequirement {
  id                String    @id @default(cuid())
  
  // User who submitted the requirement
  userId            String?
  referrerId        String?   // Health worker who referred
  referrerName      String?
  
  // Patient Info
  patientName       String
  patientPhone      String
  patientAge        Int?
  patientGender     String?
  patientAddress    String?
  
  // Location
  district          String?
  state             String?
  pincode           String?
  latitude          Float?
  longitude         Float?
  
  // Test Requirements
  testCategory      String    // blood, urine, imaging, pathology, cardiac, etc.
  tests             String    // JSON array of test names required
  urgency           String    @default("normal") // urgent, normal, routine
  preferredDate     DateTime?
  homeCollection    Boolean   @default(false)
  
  // Additional Info
  prescriptionUrl   String?   // Doctor's prescription if any
  symptoms          String?   // JSON array of symptoms
  notes             String?
  budget            String?   // User's budget range
  
  // Lab Responses - Labs that have shown interest
  labResponses      String    @default("[]") // JSON array of {labId, labName, quotedPrice, message, respondedAt}
  
  // Selected Lab
  selectedLabId     String?
  selectedLabName   String?
  quotedPrice       Float?
  
  // Status
  status            String    @default("open") // open, responding, confirmed, completed, cancelled
  
  // Earnings
  commissionRate    Float     @default(10)
  commissionEarned  Float     @default(0)
  platformFee       Float     @default(0)
  
  // Timestamps
  expiresAt         DateTime? // Requirement expiry
  confirmedAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Lab Test Catalog
model LabTestCatalog {
  id                String    @id @default(cuid())
  
  testName          String
  testCode          String?
  category          String    // blood, urine, imaging, pathology, cardiac
  subCategory       String?
  
  description       String?
  preparation       String?   // Fasting, etc.
  sampleType        String?   // Blood, urine, etc.
  
  minPrice          Float     // Minimum market price
  maxPrice          Float     // Maximum market price
  avgPrice          Float     // Average price
  homeCollectionAvailable Boolean @default(true)
  
  reportsIn         String?   // e.g., "24-48 hours"
  
  isActive          Boolean   @default(true)
  isPopular         Boolean   @default(false)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
