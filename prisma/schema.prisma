// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id            String    @id @default(cuid())
  phone         String    @unique
  email         String?
  name          String
  password      String?
  language      String    @default("hi") // Hindi default
  role          String    @default("citizen") // citizen, health_worker, admin, doctor
  aadhaarHash   String?
  address       String?
  district      String?
  state         String?
  pincode       String?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  symptoms      SymptomReport[]
  patients      Patient[]
  alerts        Alert[]
  vaccinations  VaccinationRecord[]
  appointments  Appointment[]
  emergencies   Emergency[]
  feedback      Feedback[]
}

// Patient Records (for health workers to manage)
model Patient {
  id                String    @id @default(cuid())
  userId            String?
  user              User?     @relation(fields: [userId], references: [id])
  
  // Basic Info
  name              String
  age               Int
  gender            String
  phone             String
  aadhaarHash       String?
  
  // Location
  village           String?
  district          String?
  state             String?
  pincode           String?
  latitude          Float?
  longitude         Float?
  
  // Health Info
  bloodGroup        String?
  allergies         String?
  chronicConditions String?
  isHighRisk        Boolean   @default(false)
  pregnancyDueDate  DateTime?
  
  // Assigned Health Worker
  healthWorkerId    String?
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  symptoms          SymptomReport[]
  vaccinations      VaccinationRecord[]
  appointments      Appointment[]
  emergencies       Emergency[]
  healthRecords     HealthRecord[]
}

// Health Facility Network
model HealthFacility {
  id                String    @id @default(cuid())
  name              String
  type              String    // PHC, CHC, District Hospital, Private Clinic
  address           String
  district          String
  state             String
  pincode           String
  latitude          Float
  longitude         Float
  
  // Contact
  phone             String
  emergencyPhone    String?
  email             String?
  
  // Services
  services          String    // JSON array of services
  specialties       String?   // JSON array of specialties
  bedCapacity       Int?
  availableBeds     Int?
  
  // Status
  isOpen            Boolean   @default(true)
  crowdLevel        String    @default("low") // low, moderate, high
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  appointments      Appointment[]
  medicineStock     MedicineStock[]
}

// Medicine & Supply Tracking
model MedicineStock {
  id              String    @id @default(cuid())
  facilityId      String
  facility        HealthFacility @relation(fields: [facilityId], references: [id])
  
  medicineName    String
  genericName     String?
  quantity        Int
  unit            String
  minStock        Int
  expiryDate      DateTime?
  
  lastUpdated     DateTime  @default(now())
  createdAt       DateTime  @default(now())
}

// Symptom Reports & AI Triage
model SymptomReport {
  id              String    @id @default(cuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  patientId       String?
  patient         Patient?  @relation(fields: [patientId], references: [id])
  
  // Input
  symptoms        String    // JSON array of symptoms
  inputType       String    @default("text") // text, voice, image
  imageUrl        String?
  voiceUrl        String?
  transcription   String?
  
  // Location at time of report
  latitude        Float?
  longitude       Float?
  district        String?
  
  // AI Analysis
  aiDiagnosis     String?   // JSON with diagnosis suggestions
  severity        String    @default("low") // low, moderate, high, critical
  recommendation  String?
  homeRemedies    String?   // JSON array
  nearbyFacilities String?  // JSON array of facility IDs
  
  // Outbreak Detection
  isOutbreakSignal Boolean  @default(false)
  outbreakType     String?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Health Worker Alerts
model Alert {
  id              String    @id @default(cuid())
  title           String
  message         String
  type            String    // outbreak, emergency, followup, vaccination, stock_alert
  priority        String    @default("medium") // low, medium, high, critical
  
  // Targeting
  targetType      String    // all, district, facility, health_worker, patient
  targetId        String?
  district        String?
  
  // Source
  createdBy       String?
  user            User?     @relation(fields: [createdBy], references: [id])
  
  // Status
  status          String    @default("active") // active, acknowledged, resolved
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Vaccination Records
model VaccinationRecord {
  id              String    @id @default(cuid())
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  
  vaccineName     String
  doseNumber      Int
  totalDoses      Int
  administeredDate DateTime
  nextDueDate     DateTime?
  facilityId      String?
  batchNumber     String?
  
  // Reminders
  reminderSent    Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Appointments
model Appointment {
  id              String    @id @default(cuid())
  patientId       String?
  patient         Patient?  @relation(fields: [patientId], references: [id])
  facilityId      String?
  facility        HealthFacility? @relation(fields: [facilityId], references: [id])
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  doctorId        String?   // Link to Doctor
  timeSlotId      String?   // Link to DoctorTimeSlot
  
  // Appointment Details
  appointmentDate DateTime
  appointmentTime String
  endTime         String?   // End time of appointment
  duration        Int       @default(15) // Duration in minutes
  
  // Type & Mode
  type            String    // checkup, followup, vaccination, emergency, consultation
  mode            String    @default("in_person") // in_person, video, audio
  reason          String?   // Reason for visit
  symptoms        String?   // JSON array of symptoms
  
  // Status
  status          String    @default("scheduled") // scheduled, confirmed, in_progress, completed, cancelled, no_show
  
  // Payment
  fee             Float?
  paymentStatus   String    @default("pending") // pending, paid, refunded
  paymentMethod   String?   // cash, upi, card, insurance
  
  // Confirmation & Reminders
  confirmationCode String?  // Unique code for patient
  reminderSent    Boolean   @default(false)
  reminderSentAt  DateTime?
  
  // Cancellation
  cancelledAt     DateTime?
  cancelledBy     String?
  cancellationReason String?
  
  // Consultation
  consultationId  String?   // Link to Consultation if video/audio
  
  // Follow-up
  followUpRequired Boolean  @default(false)
  followUpDate    DateTime?
  
  // Notes
  notes           String?   // Patient notes
  doctorNotes     String?   // Doctor's notes (private)
  
  // Check-in
  checkedInAt     DateTime?
  checkInMethod   String?   // self, staff, qr_code
  
  // Rating
  patientRating   Int?
  patientReview   String?
  ratedAt         DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Emergency Records
model Emergency {
  id              String    @id @default(cuid())
  patientId       String?
  patient         Patient?  @relation(fields: [patientId], references: [id])
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  
  type            String    // medical, pregnancy, accident, disaster
  description     String
  severity        String    @default("high")
  
  // Location
  latitude        Float?
  longitude       Float?
  address         String?
  district        String?
  
  // Response
  status          String    @default("active") // active, responded, resolved
  responderId     String?
  responseTime    DateTime?
  resolvedAt      DateTime?
  
  // AI First Aid
  aiFirstAidAdvice String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Health Records
model HealthRecord {
  id              String    @id @default(cuid())
  patientId       String?
  patient         Patient?  @relation(fields: [patientId], references: [id])
  userId          String?   // User who owns this record
  
  // Type & Category
  type            String    // prescription, lab_report, diagnosis, discharge_summary, imaging, vaccination, vital_signs, consultation_notes
  category        String?   // general, cardiology, orthopedics, etc.
  title           String
  description     String?
  
  // File attachments
  fileUrl         String?
  fileName        String?
  fileType        String?   // pdf, image, etc.
  fileSize        Int?
  
  // Medical Details
  doctorId        String?   // Link to Doctor
  doctorName      String?
  facilityId      String?
  facilityName    String?
  appointmentId   String?   // Link to Appointment
  
  // Diagnosis
  diagnosis       String?   // Primary diagnosis
  secondaryDiagnoses String? // JSON array of secondary diagnoses
  icdCode         String?   // ICD-10 code
  symptoms        String?   // JSON array of symptoms
  
  // Vital Signs
  bloodPressureSystolic Int?
  bloodPressureDiastolic Int?
  heartRate       Int?
  temperature     Float?
  respiratoryRate Int?
  oxygenSaturation Int?
  weight          Float?
  height          Float?
  bmi             Float?
  bloodGroup      String?
  
  // Prescription
  prescription    String?   // JSON array of medicines
  
  // Lab Results
  labResults      String?   // JSON array of lab test results
  
  // Follow-up
  followUpRequired Boolean  @default(false)
  followUpDate    DateTime?
  followUpNotes   String?
  
  // Access Control
  isPrivate       Boolean   @default(false)
  sharedWith      String?   // JSON array of user IDs
  
  // Verification
  isVerified      Boolean   @default(false)
  verifiedBy      String?
  verifiedAt      DateTime?
  
  // Tags
  tags            String?   // JSON array of tags
  
  recordDate      DateTime
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  labResultsList  LabResult[]
}

// Lab Results
model LabResult {
  id              String    @id @default(cuid())
  healthRecordId  String?
  healthRecord    HealthRecord? @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  patientId       String?
  userId          String?
  
  // Test Info
  testName        String
  testCode        String?
  testCategory    String?   // blood, urine, imaging, etc.
  labName         String?
  labId           String?
  
  // Results
  resultValue     String
  resultUnit      String?
  referenceRange  String?
  isAbnormal      Boolean   @default(false)
  abnormalityLevel String?  // low, high, critical
  
  // Status
  status          String    @default("pending") // pending, completed, reviewed
  
  // Doctor
  orderedBy       String?
  reviewedBy      String?
  reviewedAt      DateTime?
  
  // Notes
  notes           String?
  interpretation  String?
  
  // Date
  testDate        DateTime
  reportDate      DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Outbreak Predictions
model OutbreakPrediction {
  id              String    @id @default(cuid())
  disease         String
  district        String
  state           String
  
  riskLevel       String    // low, moderate, high, critical
  probability     Float
  predictedDate   DateTime?
  
  // Contributing factors
  symptomReports  Int       @default(0)
  weatherData     String?   // JSON
  historicalData  String?   // JSON
  
  // Status
  status          String    @default("predicted") // predicted, confirmed, false_alarm
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Government Scheme Eligibility
model SchemeEligibility {
  id              String    @id @default(cuid())
  userId          String?
  
  schemeName      String    // PMJAY, Ayushman Bharat, etc.
  eligibilityStatus String  @default("pending") // pending, eligible, ineligible, enrolled
  enrollmentId    String?
  
  documents       String?   // JSON array of required documents
  verifiedAt      DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Feedback & Grievances
model Feedback {
  id              String    @id @default(cuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  
  type            String    // feedback, complaint, suggestion
  category        String?
  subject         String
  description     String
  facilityId      String?
  
  // Status
  status          String    @default("pending") // pending, in_progress, resolved
  resolution      String?
  resolvedAt      DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Transport & Ambulance
model TransportRequest {
  id              String    @id @default(cuid())
  patientId       String?
  emergencyId     String?
  
  pickupLocation  String
  pickupLat       Float?
  pickupLng       Float?
  dropLocation    String
  dropLat         Float?
  dropLng         Float?
  
  vehicleType     String    // ambulance, auto, volunteer
  status          String    @default("requested") // requested, assigned, in_transit, completed
  
  driverId        String?
  driverPhone     String?
  estimatedTime   Int?      // minutes
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Health Worker Tasks
model HealthWorkerTask {
  id              String    @id @default(cuid())
  healthWorkerId  String
  patientId       String?
  
  taskType        String    // visit, followup, vaccination, emergency
  description     String
  priority        String    @default("medium")
  
  scheduledDate   DateTime
  completedDate   DateTime?
  status          String    @default("pending") // pending, in_progress, completed, cancelled
  
  notes           String?
  
  // GPS tracking
  visitLat        Float?
  visitLng        Float?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Chat History for AI Assistant
model ChatHistory {
  id              String    @id @default(cuid())
  sessionId       String
  userId          String?
  
  role            String    // user, assistant
  content         String
  inputType       String    @default("text") // text, voice, image
  
  createdAt       DateTime  @default(now())
}

// Government Schemes Master Data
model GovernmentScheme {
  id                  String    @id @default(cuid())
  name                String    // PMJAY, Ayushman Bharat, etc.
  description         String
  shortDescription    String?
  
  // Eligibility criteria stored as JSON
  eligibilityCriteria String    // JSON object with criteria
  benefits            String    // JSON array of benefits
  documents           String    // JSON array of required documents
  
  // Coverage
  coverageAmount      String?   // e.g., "₹5 lakh per family"
  coverageType        String?   // individual, family
  
  // Target groups
  targetGroups        String?   // JSON array of target groups
  
  // Status
  isActive            Boolean   @default(true)
  
  // Official info
  officialWebsite     String?
  helpline            String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // Relations
  applications        SchemeApplication[]
}

// Scheme Applications by Users
model SchemeApplication {
  id              String    @id @default(cuid())
  userId          String
  schemeId        String
  scheme          GovernmentScheme @relation(fields: [schemeId], references: [id])
  
  // Application details
  status          String    @default("draft") // draft, submitted, under_review, approved, rejected
  applicationId   String?   // Official application ID
  
  // Documents uploaded
  documents       String    // JSON array of uploaded documents
  
  // Review info
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  
  // Enrollment
  enrollmentId    String?
  enrollmentDate  DateTime?
  
  // Timestamps
  appliedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Health Camps and Events
model HealthCamp {
  id              String    @id @default(cuid())
  title           String
  description     String?
  
  // Organizer info
  organizer       String    // Organization name
  organizerType   String    // government, ngo, hospital, corporate
  
  // Date and time
  date            DateTime
  endDate         DateTime?
  startTime       String
  endTime         String
  
  // Location
  venue           String
  address         String
  district        String
  state           String
  pincode         String?
  latitude        Float?
  longitude       Float?
  
  // Services offered
  services        String    // JSON array of services
  
  // Capacity
  capacity        Int?
  registered      Int       @default(0)
  
  // Status
  status          String    @default("upcoming") // upcoming, ongoing, completed, cancelled
  
  // Contact
  contactPerson   String?
  contactPhone    String?
  
  // Registration deadline
  registrationDeadline DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Community Forum Posts
model ForumPost {
  id              String    @id @default(cuid())
  userId          String
  
  // Content
  title           String
  content         String
  category        String    // general, pregnancy, child_health, chronic_disease, mental_health, nutrition
  
  // Replies stored as JSON array
  replies         String    @default("[]")  // JSON array of reply objects
  
  // Engagement
  views           Int       @default(0)
  likes           Int       @default(0)
  
  // Moderation
  status          String    @default("active") // active, hidden, deleted
  isPinned        Boolean   @default(false)
  
  // Tags
  tags            String?   // JSON array of tags
  
  // Last activity
  lastActivityAt  DateTime  @default(now())
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Health Challenges / Gamification
model HealthChallenge {
  id              String    @id @default(cuid())
  title           String
  description     String
  
  // Challenge type
  type            String    // steps, water, sleep, exercise, nutrition, meditation
  targetValue     Int       // e.g., 10000 steps, 8 glasses water
  
  // Duration
  startDate       DateTime
  endDate         DateTime
  durationDays    Int
  
  // Rewards
  points          Int       // Points for completion
  badge           String?   // Badge name
  
  // Participants stored as JSON
  participants    String    @default("[]")  // JSON array of {userId, progress, completed}
  
  // Stats
  totalParticipants Int     @default(0)
  completions     Int       @default(0)
  
  // Status
  status          String    @default("upcoming") // upcoming, active, completed
  
  // Difficulty
  difficulty      String    @default("medium") // easy, medium, hard
  
  // Creator
  createdBy       String?   // Admin or system generated
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Volunteer Network
model Volunteer {
  id              String    @id @default(cuid())
  userId          String
  
  // Profile
  name            String
  phone           String
  email           String?
  
  // Skills stored as JSON array
  skills          String    // JSON array: first_aid, counseling, transport, translation, etc.
  
  // Availability
  availability    String    // JSON object with days and times
  isAvailable     Boolean   @default(true)
  
  // Location
  district        String?
  state           String?
  latitude        Float?
  longitude       Float?
  
  // Verification
  verified        Boolean   @default(false)
  verifiedBy      String?
  verifiedAt      DateTime?
  
  // Experience
  experience      String?   // Years of experience or description
  certifications  String?   // JSON array of certifications
  
  // Stats
  hoursContributed Float   @default(0)
  tasksCompleted  Int       @default(0)
  rating          Float?
  
  // Emergency contact
  emergencyContact String?
  emergencyPhone  String?
  
  // Status
  status          String    @default("active") // active, inactive, suspended
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ==================== TELEMEDICINE ====================

// Doctor Profile
model Doctor {
  id                String    @id @default(cuid())
  userId            String?   // Link to User if registered
  
  // Personal Info
  name              String
  phone             String
  email             String?
  photo             String?
  dateOfBirth       DateTime?
  gender            String?
  
  // Professional Info
  specialization    String    // General Medicine, Cardiology, Pediatrics, etc.
  qualifications    String    // JSON array of degrees
  registrationNumber String?
  registrationCouncil String?  // Medical council name
  yearsOfExperience Int?
  
  // Practice Info
  facilityId        String?   // Primary facility
  facilityName      String?   // Facility name for display
  consultationFee   Float     @default(0)
  videoConsultFee   Float?
  followUpFee       Float?    // Fee for follow-up consultations
  
  languages         String    @default("[]") // JSON array of languages spoken
  bio               String?   // Short bio/description
  
  // Availability - stored as JSON
  availability      String    @default("{}") // JSON object with weekly schedule
  slotDuration      Int       @default(15) // Default slot duration in minutes
  bufferTime        Int       @default(5) // Buffer time between appointments
  
  // Online Consultation
  isAvailableOnline Boolean   @default(false)
  isAvailableInPerson Boolean @default(true)
  maxDailyAppointments Int?   // Max appointments per day
  
  // Rating & Reviews
  rating            Float     @default(0)
  totalReviews      Int       @default(0)
  
  // Verification
  isVerified        Boolean   @default(false)
  verifiedAt        DateTime?
  documents         String?   // JSON array of document URLs
  
  // Stats
  totalConsultations Int      @default(0)
  totalPatients     Int       @default(0)
  thisMonthConsultations Int  @default(0)
  
  // Status
  status            String    @default("active") // active, inactive, suspended, on_leave
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  consultations     Consultation[]
  prescriptions     Prescription[]
  schedules         DoctorSchedule[]
  leaves            DoctorLeave[]
  timeSlots         DoctorTimeSlot[]
}

// Doctor's Weekly Schedule
model DoctorSchedule {
  id                String    @id @default(cuid())
  doctorId          String
  doctor            Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  // Day of week
  dayOfWeek         Int       // 0=Sunday, 1=Monday, ..., 6=Saturday
  
  // Time slots for this day
  startTime         String    // "09:00"
  endTime           String    // "17:00"
  breakStart        String?   // Lunch break start "13:00"
  breakEnd          String?   // Lunch break end "14:00"
  
  // Consultation type available
  isOnline          Boolean   @default(true)
  isInPerson        Boolean   @default(true)
  
  // Max appointments for this day
  maxAppointments   Int?
  
  // Status
  isActive          Boolean   @default(true)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@unique([doctorId, dayOfWeek])
}

// Doctor Leave/Time Off
model DoctorLeave {
  id                String    @id @default(cuid())
  doctorId          String
  doctor            Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  // Leave details
  startDate         DateTime
  endDate           DateTime
  leaveType         String    // full_day, half_day_morning, half_day_evening
  reason            String?
  
  // Approval (for hospital managed doctors)
  status            String    @default("approved") // pending, approved, rejected
  approvedBy        String?
  approvedAt        DateTime?
  
  // Recurring
  isRecurring       Boolean   @default(false)
  recurringPattern  String?   // weekly, monthly, yearly
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Doctor Time Slots (Generated from schedule)
model DoctorTimeSlot {
  id                String    @id @default(cuid())
  doctorId          String
  doctor            Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  // Slot details
  date              DateTime
  startTime         String    // "09:00"
  endTime           String    // "09:15"
  
  // Slot type
  consultationType  String    // video, in_person, both
  
  // Status
  status            String    @default("available") // available, booked, blocked, completed
  bookedBy          String?   // Patient/Consultation ID
  bookedAt          DateTime?
  
  // Notes
  notes             String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@unique([doctorId, date, startTime])
}

// Video/Audio Consultations
model Consultation {
  id                String    @id @default(cuid())
  
  // Participants
  patientId         String?
  doctorId          String
  doctor            Doctor    @relation(fields: [doctorId], references: [id])
  userId            String?   // User who booked
  
  // Scheduling
  scheduledDate     DateTime
  scheduledTime     String    // HH:MM format
  duration          Int       @default(15) // minutes
  
  // Type
  type              String    @default("video") // video, audio, chat
  reason            String?   // Patient's reason for consultation
  
  // Payment
  fee               Float
  paymentStatus     String    @default("pending") // pending, paid, refunded
  
  // Video Call
  videoLink         String?   // Generated video call link
  roomCode          String?   // Room ID for video call
  
  // Status
